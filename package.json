{
  "name": "vsc-project-notes",
  "displayName": "Project Notes",
  "description": "Workspace-specific notes panel for VS Code",
  "version": "1.0.1",
  "publisher": "coderm4ster",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coderm4ster/vsc-project-notes"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-notes-container",
          "title": "Project Notes",
          "icon": "media/notepad.svg"
        }
      ]
    },
    "views": {
      "project-notes-container": [
        {
          "id": "projectNotesView",
          "name": "Project Notes",
          "icon": "media/notepad.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "project-notes.createNote",
        "title": "New Note",
        "icon": "$(add)",
        "category": "Project Notes"
      },
      {
        "command": "project-notes.openNote",
        "title": "Open Note",
        "category": "Project Notes"
      },
      {
        "command": "project-notes.renameNote",
        "title": "Rename Note",
        "icon": "$(edit)",
        "category": "Project Notes"
      },
      {
        "command": "project-notes.deleteNote",
        "title": "Delete Note",
        "icon": "$(trash)",
        "category": "Project Notes"
      }
    ],
    "viewsWelcome": [
      {
        "view": "projectNotesView",
        "contents": "Open a folder or workspace to use Project Notes.\n[Open Folder](command:vscode.openFolder)",
        "when": "workspaceFolderCount == 0"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "project-notes.createNote",
          "when": "view == projectNotesView && workspaceFolderCount != 0",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "project-notes.renameNote",
          "when": "view == projectNotesView && viewItem == note",
          "group": "inline@1"
        },
        {
          "command": "project-notes.deleteNote",
          "when": "view == projectNotesView && viewItem == note",
          "group": "inline@2"
        },
        {
          "command": "project-notes.openNote",
          "when": "view == projectNotesView && viewItem == note",
          "group": "1_actions@1"
        },
        {
          "command": "project-notes.renameNote",
          "when": "view == projectNotesView && viewItem == note",
          "group": "1_actions@2"
        },
        {
          "command": "project-notes.deleteNote",
          "when": "view == projectNotesView && viewItem == note",
          "group": "1_actions@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.x",
    "typescript": "^5.3.0"
  }
}
